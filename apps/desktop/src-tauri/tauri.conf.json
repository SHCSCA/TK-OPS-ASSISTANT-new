{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TK-OPS",
  "version": "1.3.2",
  "identifier": "com.tkops.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web -- --host 127.0.0.1 --port 4173",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TK-OPS",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "TK-OPS",
        "url": "/splash.html",
        "width": 480,
        "height": 320,
        "resizable": false,
        "center": true,
        "decorations": false,
        "alwaysOnTop": true,
        "maximizable": false,
        "minimizable": false,
        "closable": false
      }
    ]
  }
}
